{
  "name": "@sweny-ai/engine",
  "version": "3.2.0",
  "description": "Workflow engine for SWEny — composable DAG-based agentic workflows",
  "type": "module",
  "keywords": [
    "workflow",
    "dag",
    "orchestration",
    "ai",
    "automation",
    "devops",
    "sweny"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "schema",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser.js",
    "./builtin-steps": "./dist/builtin-steps.js",
    "./schema": "./schema/workflow-definition.schema.json"
  },
  "dependencies": {
    "@sweny-ai/providers": ">=1.1.0"
  },
  "peerDependencies": {
    "@sweny-ai/providers": ">=1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "ajv": "^8.18.0",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://sweny.ai",
  "bugs": {
    "url": "https://github.com/swenyai/sweny/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/engine"
