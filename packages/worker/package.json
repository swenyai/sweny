{
  "name": "@sweny-ai/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SWEny open-source job executor — runs triage and implement recipes from a BullMQ queue",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sweny-ai/engine": "*",
    "@sweny-ai/providers": "*",
    "@sweny-ai/shared": "*",
    "bullmq": "^5"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^4"
  }
}
