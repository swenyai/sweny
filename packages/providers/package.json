{
  "name": "@swenyai/providers",
  "version": "0.2.0",
  "description": "Shared provider interfaces and implementations for SWEny",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./dist/index.js",
    "./observability": "./dist/observability/index.js",
    "./issue-tracking": "./dist/issue-tracking/index.js",
    "./notification": "./dist/notification/index.js",
    "./source-control": "./dist/source-control/index.js",
    "./incident": "./dist/incident/index.js",
    "./messaging": "./dist/messaging/index.js",
    "./auth": "./dist/auth/index.js",
    "./access": "./dist/access/index.js",
    "./storage": "./dist/storage/index.js",
    "./coding-agent": "./dist/coding-agent/index.js",
    "./agent-tool": "./dist/agent-tool/index.js",
    "./credential-vault": "./dist/credential-vault/index.js"
  },
  "typesVersions": {
    "*": {
      "observability": [
        "dist/observability/index.d.ts"
      ],
      "issue-tracking": [
        "dist/issue-tracking/index.d.ts"
      ],
      "notification": [
        "dist/notification/index.d.ts"
      ],
      "source-control": [
        "dist/source-control/index.d.ts"
      ],
      "incident": [
        "dist/incident/index.d.ts"
      ],
      "messaging": [
        "dist/messaging/index.d.ts"
      ],
      "auth": [
        "dist/auth/index.d.ts"
      ],
      "access": [
        "dist/access/index.d.ts"
      ],
      "storage": [
        "dist/storage/index.d.ts"
      ],
      "coding-agent": [
        "dist/coding-agent/index.d.ts"
      ],
      "agent-tool": [
        "dist/agent-tool/index.d.ts"
      ],
      "credential-vault": [
        "dist/credential-vault/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "zod": "^3.24"
  },
  "peerDependencies": {
    "@actions/core": "^1.10",
    "@actions/exec": "^1.1",
    "@aws-sdk/client-cloudwatch-logs": "^3",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/client-secrets-manager": "^3",
    "@aws-sdk/credential-provider-node": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@slack/web-api": "^7"
  },
  "peerDependenciesMeta": {
    "@actions/core": {
      "optional": true
    },
    "@actions/exec": {
      "optional": true
    },
    "@aws-sdk/client-cloudwatch-logs": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/client-secrets-manager": {
      "optional": true
    },
    "@aws-sdk/credential-provider-node": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@slack/web-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@actions/core": "^1.10",
    "@actions/exec": "^1.1",
    "@aws-sdk/client-cloudwatch-logs": "^3",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/client-secrets-manager": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@slack/web-api": "^7",
    "@types/node": "^22",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "license": "MIT",
  "homepage": "https://sweny.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/providers"
  }
}
