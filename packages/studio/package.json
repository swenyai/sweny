{
  "name": "@sweny-ai/studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist/lib"
  ],
  "exports": {
    ".": {
      "import": "./dist/lib/viewer.js",
      "types": "./dist/lib/types/lib-viewer.d.ts"
    },
    "./editor": {
      "import": "./dist/lib/editor.js",
      "types": "./dist/lib/types/lib-editor.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc --project tsconfig.lib.json && BUILD_MODE=lib vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sweny-ai/engine": "*",
    "@xyflow/react": "^12.0.0",
    "elkjs": "^0.9.0",
    "immer": "^11.1.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zundo": "^2.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@xyflow/react": "^12.0.0",
    "elkjs": "^0.9.0"
  }
}
