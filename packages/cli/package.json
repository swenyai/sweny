{
  "name": "@swenyai/cli",
  "version": "0.2.0",
  "description": "SWEny CLI — run triage workflows locally",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "sweny": "./dist/main.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@swenyai/engine": "*",
    "@swenyai/providers": "*",
    "chalk": "^5",
    "commander": "^11"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "license": "MIT",
  "homepage": "https://sweny.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/cli"
  }
}
