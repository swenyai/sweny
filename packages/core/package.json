{
  "name": "@sweny-ai/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Skill library + DAG workflow orchestration powered by Claude",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser.js",
    "./studio": "./dist/studio.js",
    "./skills": "./dist/skills/index.js",
    "./workflows": "./dist/workflows/index.js",
    "./testing": "./dist/testing.js",
    "./schema": "./dist/schema.js"
  },
  "typesVersions": {
    "*": {
      "browser": [
        "dist/browser.d.ts"
      ],
      "studio": [
        "dist/studio.d.ts"
      ],
      "skills": [
        "dist/skills/index.d.ts"
      ],
      "workflows": [
        "dist/workflows/index.d.ts"
      ],
      "testing": [
        "dist/testing.d.ts"
      ],
      "schema": [
        "dist/schema.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/__tests__/integration/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.85",
    "vitest": "^3.2.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://sweny.ai",
  "bugs": {
    "url": "https://github.com/swenyai/sweny/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/core"
  },
  "keywords": [
    "workflow",
    "dag",
    "skills",
    "claude",
    "ai",
    "automation",
    "devops",
    "sweny"
  ]
}
