{
  "name": "@sweny-ai/agent",
  "version": "0.1.0",
  "description": "AI assistant framework powered by Claude Code SDK — Slack bot + CLI with plugin architecture",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx --env-file=.env src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./dist/index.js",
    "./channel": "./dist/channel/index.js",
    "./orchestrator": "./dist/orchestrator.js",
    "./plugins": "./dist/plugins/types.js",
    "./runner": "./dist/runner/index.js",
    "./config": "./dist/config/types.js",
    "./auth": "./dist/auth/types.js",
    "./session": "./dist/session/manager.js",
    "./storage": "./dist/storage/types.js"
  },
  "typesVersions": {
    "*": {
      "channel": [
        "dist/channel/index.d.ts"
      ],
      "orchestrator": [
        "dist/orchestrator.d.ts"
      ],
      "plugins": [
        "dist/plugins/types.d.ts"
      ],
      "runner": [
        "dist/runner/index.d.ts"
      ],
      "config": [
        "dist/config/types.d.ts"
      ],
      "auth": [
        "dist/auth/types.d.ts"
      ],
      "session": [
        "dist/session/manager.d.ts"
      ],
      "storage": [
        "dist/storage/types.d.ts"
      ]
    }
  },
  "dependencies": {
    "@slack/bolt": "^4",
    "@sweny-ai/providers": "*",
    "express": "^5",
    "zod": "^4.3"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": "^1",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/credential-provider-node": "^3",
    "@aws-sdk/s3-request-presigner": "^3"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-code": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/credential-provider-node": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^1",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@types/express": "^5",
    "@types/node": "^25",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "keywords": [
    "ai",
    "assistant",
    "claude",
    "slack",
    "mcp",
    "agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://sweny.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/agent"
  }
}
