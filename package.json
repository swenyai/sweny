{
  "name": "sweny",
  "type": "module",
  "private": true,
  "description": "SWEny — autonomous engineering tools",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:agent": "npm run dev --workspace=packages/agent",
    "cli:agent": "npm run cli --workspace=packages/agent",
    "dev:web": "npm run dev --workspace=packages/web",
    "build:web": "npm run build --workspace=packages/web",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "cli:triage": "npm run dev --workspace=packages/cli -- triage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "release": "changeset publish"
  },
  "license": "MIT",
  "homepage": "https://sweny.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md,mdx}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "svgo": "^4.0.1",
    "fast-xml-parser": "^5.5.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "fast-xml-parser": "^5.5.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
