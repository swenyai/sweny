{
  "name": "@sweny-ai/cli",
  "version": "1.10.2",
  "description": "SWEny CLI — run AI-powered triage and workflow automation locally",
  "type": "module",
  "keywords": [
    "workflow",
    "cli",
    "ai",
    "triage",
    "devops",
    "debugging",
    "automation",
    "sweny"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "sweny": "./dist/main.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sweny-ai/engine": "*",
    "@sweny-ai/providers": "*",
    "chalk": "^5",
    "commander": "^14",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://sweny.ai",
  "bugs": {
    "url": "https://github.com/swenyai/sweny/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/cli"
  }
}
