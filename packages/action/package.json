{
  "name": "@sweny-ai/action",
  "version": "0.1.0",
  "description": "Autonomous SRE triage GitHub Action — monitors logs, creates issues, opens fix PRs",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "package": "ncc build src/main.ts -o ../../dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "all": "npm run build && npm run package"
  },
  "dependencies": {
    "@actions/core": "^3.0",
    "@actions/exec": "^1.1",
    "@actions/github": "^6",
    "@actions/io": "^1.1",
    "@sweny-ai/engine": "*",
    "@sweny-ai/providers": "*"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@vercel/ncc": "^0.38",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "keywords": [
    "sre",
    "triage",
    "github-action",
    "claude",
    "observability",
    "linear"
  ],
  "homepage": "https://sweny.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/action"
  }
}
