{
  "name": "@sweny-ai/studio",
  "version": "8.0.19",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/lib"
  ],
  "exports": {
    ".": {
      "import": "./dist/lib/viewer.js",
      "types": "./dist/lib/types/lib-viewer.d.ts"
    },
    "./viewer": {
      "import": "./dist/lib/viewer.js",
      "types": "./dist/lib/types/lib-viewer.d.ts"
    },
    "./editor": {
      "import": "./dist/lib/editor.js",
      "types": "./dist/lib/types/lib-editor.d.ts"
    },
    "./style.css": "./dist/lib/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "BUILD_MODE=lib vite build && tsc --project tsconfig.lib.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sweny-ai/core": "*",
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.9.0",
    "immer": "^11.1.8",
    "yaml": "^2.9.0",
    "zundo": "^2.3.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.9.0"
  }
}
