{
  "name": "@sweny/action",
  "version": "0.1.0",
  "description": "Autonomous SRE triage GitHub Action — monitors logs, creates issues, opens fix PRs",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "package": "ncc build src/main.ts -o ../../dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "all": "npm run build && npm run package"
  },
  "dependencies": {
    "@actions/core": "^1.10",
    "@actions/exec": "^1.1",
    "@actions/github": "^6",
    "@actions/io": "^1.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vercel/ncc": "^0.38",
    "typescript": "^5.6",
    "vitest": "^4"
  },
  "keywords": ["sre", "triage", "github-action", "claude", "observability", "linear"],
  "homepage": "https://sweny.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/action"
  }
}
