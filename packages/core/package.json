{
  "name": "@sweny-ai/core",
  "version": "0.1.77",
  "type": "module",
  "bin": {
    "sweny": "./dist/cli/main.js"
  },
  "description": "Skill library, DAG workflow orchestration, and E2E browser testing powered by Claude",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser.js",
    "./studio": "./dist/studio.js",
    "./skills": "./dist/skills/index.js",
    "./workflows": "./dist/workflows/index.js",
    "./testing": "./dist/testing.js",
    "./schema": "./dist/schema.js",
    "./new": "./dist/cli/new.js"
  },
  "typesVersions": {
    "*": {
      "browser": [
        "dist/browser.d.ts"
      ],
      "studio": [
        "dist/studio.d.ts"
      ],
      "skills": [
        "dist/skills/index.d.ts"
      ],
      "workflows": [
        "dist/workflows/index.d.ts"
      ],
      "testing": [
        "dist/testing.d.ts"
      ],
      "schema": [
        "dist/schema.d.ts"
      ],
      "new": [
        "dist/cli/new.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/workflows/*.yml dist/workflows/ && node scripts/build-workflow-browser.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/__tests__/integration/**' --exclude 'dist/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@clack/prompts": "^1.2.0",
    "chalk": "^5",
    "commander": "^13",
    "yaml": "^2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.114",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://sweny.ai",
  "bugs": {
    "url": "https://github.com/swenyai/sweny/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swenyai/sweny.git",
    "directory": "packages/core"
  },
  "keywords": [
    "workflow",
    "dag",
    "skills",
    "claude",
    "ai",
    "automation",
    "devops",
    "sweny"
  ]
}
