# .env.example — copy to .env and fill in the values you need
# cp .env.example .env
#
# You only need the vars for the providers you're using.
# Select providers in .sweny.yml (created by `sweny new`).
#
# Priority order: CLI flag > env var (.env) > .sweny.yml > default
#
# ─────────────────────────────────────────────────────────────────────────────
# MINIMUM to run a local dry-run (no external services needed):
#   1. Set CLAUDE_CODE_OAUTH_TOKEN (recommended) or ANTHROPIC_API_KEY
#   2. In .sweny.yml set:
#        observability-provider: file
#        issue-tracker-provider: file
#        source-control-provider: file
#        notification-provider: file
# ─────────────────────────────────────────────────────────────────────────────


# === Coding Agent ============================================================
# Required — pick one:

# Recommended: uses your Claude Max subscription (no per-token billing)
#CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: pay-per-use Anthropic API key (console.anthropic.com)
#ANTHROPIC_API_KEY=

# For codex provider (OpenAI)
#OPENAI_API_KEY=

# For gemini provider (Google AI Studio or Vertex)
#GEMINI_API_KEY=
#GOOGLE_API_KEY=   # alias for GEMINI_API_KEY


# === Observability ============================================================
# Set the vars for whichever observability-provider you chose in .sweny.yml

# Datadog (observability-provider: datadog)
#DD_API_KEY=       # Organization Settings > API Keys
#DD_APP_KEY=       # Organization Settings > Application Keys
#DD_SITE=          # datadoghq.com | datadoghq.eu | us3.datadoghq.com | etc. (default: datadoghq.com)

# Sentry (observability-provider: sentry)
#SENTRY_AUTH_TOKEN=   # sentry.io > Settings > Auth Tokens
#SENTRY_ORG=          # your organization slug
#SENTRY_PROJECT=      # your project slug (optional — searches all projects if omitted)
#SENTRY_BASE_URL=     # default: https://sentry.io (override for self-hosted)

# AWS CloudWatch (observability-provider: cloudwatch)
#AWS_REGION=                    # e.g. us-east-1
#CLOUDWATCH_LOG_GROUP_PREFIX=   # e.g. /aws/lambda (optional prefix filter)
# Uses standard AWS credential chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / instance profile)

# Splunk (observability-provider: splunk)
#SPLUNK_URL=     # e.g. https://your-instance.splunkcloud.com
#SPLUNK_TOKEN=   # HTTP Event Collector or Search token
#SPLUNK_INDEX=   # default: main

# Elastic (observability-provider: elastic)
#ELASTIC_URL=      # e.g. https://my-cluster.es.io:9243
#ELASTIC_API_KEY=  # Base64-encoded API key
#ELASTIC_INDEX=    # default: logs-*

# New Relic (observability-provider: newrelic)
#NR_API_KEY=     # User API key (NRAK-...)
#NR_ACCOUNT_ID=  # your numeric account ID
#NR_REGION=      # US | EU (default: US)

# Loki (observability-provider: loki)
#LOKI_URL=      # e.g. http://localhost:3100 or https://logs-prod.grafana.net
#LOKI_API_KEY=  # Bearer token (required for Grafana Cloud)
#LOKI_ORG_ID=   # X-Scope-OrgID header (multi-tenant Loki only)


# === Issue Tracking ===========================================================

# GitHub Issues (issue-tracker-provider: github-issues)
#GITHUB_TOKEN=   # Personal Access Token with repo scope (github.com/settings/tokens)

# Linear (issue-tracker-provider: linear)
#LINEAR_API_KEY=             # linear.app > Settings > API
#LINEAR_TEAM_ID=             # required: your team's ID (e.g. TEAM-abc123)
#LINEAR_BUG_LABEL_ID=        # optional: label ID to apply to bug issues
#LINEAR_TRIAGE_LABEL_ID=     # optional: label ID for triage issues
#LINEAR_STATE_BACKLOG=       # optional: state name for backlog (default: Backlog)
#LINEAR_STATE_IN_PROGRESS=   # optional: state name for in-progress (default: In Progress)
#LINEAR_STATE_PEER_REVIEW=   # optional: state name for peer review (default: In Review)

# Jira (issue-tracker-provider: jira)
#JIRA_BASE_URL=    # e.g. https://yourcompany.atlassian.net
#JIRA_EMAIL=       # your Atlassian account email
#JIRA_API_TOKEN=   # id.atlassian.com > Security > API tokens


# === Source Control ===========================================================

# GitHub (source-control-provider: github)
#GITHUB_TOKEN=             # same token as above — reused if already set
#GITHUB_REPOSITORY=        # owner/repo — auto-detected from git remote if not set
#GITHUB_REPOSITORY_OWNER=  # optional override for the org/user portion

# GitLab (source-control-provider: gitlab)
#GITLAB_TOKEN=       # Personal Access Token with api scope
#GITLAB_PROJECT_ID=  # numeric project ID
#GITLAB_BASE_URL=    # default: https://gitlab.com (override for self-hosted)


# === Notifications ============================================================

# Slack (notification-provider: slack)
#NOTIFICATION_WEBHOOK_URL=   # Incoming Webhook URL from api.slack.com/apps

# Microsoft Teams (notification-provider: teams)
#NOTIFICATION_WEBHOOK_URL=   # Incoming Webhook URL from Teams connector

# Discord (notification-provider: discord)
#NOTIFICATION_WEBHOOK_URL=   # Discord Webhook URL from channel settings

# Email via SendGrid (notification-provider: email)
#SENDGRID_API_KEY=   # app.sendgrid.com > Settings > API Keys
#EMAIL_FROM=         # verified sender address (e.g. alerts@yourcompany.com)
#EMAIL_TO=           # recipient address

# Custom webhook (notification-provider: webhook)
#NOTIFICATION_WEBHOOK_URL=   # your endpoint URL
#WEBHOOK_SIGNING_SECRET=     # optional — used for HMAC-SHA256 request signing


# === Agent (Slack bot) ========================================================
# Only needed when running @sweny-ai/agent as a Slack bot

#BOT_TOKEN=   # Slack Bot User OAuth Token (xoxb-...)


# === MCP Servers ==============================================================
# Optional — inject additional tools into the coding agent via MCP.
# See docs/mcp-servers.md for a full catalog and copy-paste configs.
# Value must be a JSON object (each key is a server name you choose).
#
# Example: GitHub MCP server
#SWENY_MCP_SERVERS={"github":{"type":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-github@latest"],"env":{"GITHUB_PERSONAL_ACCESS_TOKEN":"ghp_..."}}}


# === SWEny internals ==========================================================

#SWENY_CACHE_DIR=       # default: .sweny/cache
#SWENY_OUTPUT_DIR=      # default: .sweny/output
#SWENY_LOG_FILE=        # path to a JSON log file (for observability-provider: file)
#SWENY_WORKSPACE_TOOLS= # comma-separated list of workspace tool names to enable
